# Lyra web — environment

# Python backend (the agent-turn seam). The app POSTs to `${BACKEND_URL}/turn`.
# If unset or unreachable, /api/agent falls back to the local mock agent so the
# demo never dies. Local: http://localhost:8010 · prod: the Replit URL.
BACKEND_URL=http://localhost:8010

# ElevenLabs voice-out (WS-V) — optional, only when wiring Lyra's narration voice.
# ELEVENLABS_API_KEY=
