# Spotify Web API — Client Credentials Flow (public playlists only, no user auth)
# Create an app at https://developer.spotify.com/dashboard and copy the values here.
# Then: cp .env.example .env  and fill them in. NEVER commit the real .env.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI saved in the app settings on the dashboard.
# Reading /playlists/{id}/items now requires user auth (Authorization Code flow).
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback
