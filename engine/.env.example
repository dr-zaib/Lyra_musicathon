# Lyra engine + backend — environment.
# Setup (any OS): copy this file to `engine/.env` and fill in the values.
#   macOS/Linux:  cp .env.example .env
#   Windows PS:   Copy-Item .env.example .env
# The backend loads this same file (see backend/agent.py). NEVER commit the real .env.

# ── RUNTIME-REQUIRED (the backend/engine won't work without these) ───────────
# Musixmatch API — lyrics analysis (analysis.get / analysis.search / richsync).
MUSIXMATCH_API_KEY=
# Anthropic API — the agent (interpret/narrate) + the soft-map Claude fallback.
ANTHROPIC_API_KEY=

# ── SEED-ONLY (NOT needed to run the demo) ──────────────────────────────────
# Only used to REGENERATE the Spotify seed dataset. The enriched seed is already
# committed (engine/data/seed_enriched.json), so leave these blank to just run.
# Create an app at https://developer.spotify.com/dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI saved in the app settings on the dashboard.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback
